{
  "mode": "local_eml",
  "input_path": "research/data/raw/subscription_emails",
  "enabled_services": [
    "seeking_alpha",
    "tradevision",
    "zacks"
  ],
  "allowed_sender_domains": [
    "seekingalpha.com",
    "email.seekingalpha.com",
    "tradevision.io",
    "tradevision.com",
    "zacks.com",
    "zacksalerts.com"
  ],
  "tickers": [
    "AAPL",
    "MSFT",
    "NVDA"
  ],
  "lookback_days": 30,
  "unmatched_ticker_policy": "manual_review",
  "mailbox_label": "Trading Agency",
  "token_path": "research/config/subscription-email-token.local.json",
  "follow_article_links": false,
  "article_link_domains": [
    "seekingalpha.com",
    "email.seekingalpha.com",
    "tradevision.io",
    "tradevision.com",
    "zacks.com"
  ],
  "article_max_links_per_email": 1,
  "article_max_total_per_run": 5,
  "article_fetch_timeout_seconds": 15,
  "article_max_chars": 12000,
  "article_fetch_mode": "auto",
  "article_browser_state_dir": "research/config/browser-sessions",
  "article_analysis_cache_path": "research/config/article-analysis-cache.local.json",
  "article_browser_wait_seconds": 5,
  "article_browser_channel": "chrome",
  "article_browser_headless": true,
  "article_browser_cdp_url": null,
  "article_login_preflight_required": false,
  "article_login_preflight_services": [
    "seeking_alpha"
  ],
  "article_llm_analysis_enabled": false,
  "article_llm_provider": "openai",
  "article_llm_model": "gpt-5-nano",
  "article_llm_timeout_seconds": 45,
  "mailbox_host": null,
  "mailbox_port": 993,
  "mailbox_username_env": "SUBSCRIPTION_EMAIL_USERNAME",
  "mailbox_password_env": "SUBSCRIPTION_EMAIL_PASSWORD",
  "mailbox_search": "UNSEEN",
  "mailbox_unseen_only": true,
  "mailbox_max_messages": 10,
  "mailbox_mark_seen": false,
  "monitor_poll_seconds": 60
}
