{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://trading-agency.local/schemas/candidate-lifecycle-event.schema.json",
  "title": "CandidateLifecycleEvent",
  "x-version": "0.1.0",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "event_id",
    "cycle_id",
    "ticker",
    "event_type",
    "event_time",
    "status",
    "reason",
    "payload"
  ],
  "properties": {
    "schema_version": {
      "const": "0.1.0"
    },
    "event_id": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "cycle_id": {
      "type": "string",
      "minLength": 1
    },
    "ticker": {
      "type": "string",
      "pattern": "^[A-Z][A-Z0-9.-]{0,9}$"
    },
    "event_type": {
      "type": "string",
      "enum": [
        "ENTERED_UNIVERSE",
        "PASSED_FUNDAMENTALS",
        "DETERMINISTIC_ACTION",
        "LLM_ACTION",
        "FINAL_ACTION",
        "HUMAN_REVIEW",
        "RISK_DECISION",
        "EXECUTION_PREVIEW",
        "EXECUTION_STATE",
        "PORTFOLIO_MONITOR",
        "LEARNING_OUTCOME",
        "DEMOTED",
        "REMOVED"
      ]
    },
    "event_time": {
      "type": "string",
      "format": "date-time"
    },
    "status": {
      "type": "string",
      "enum": [
        "RECORDED",
        "PASSED",
        "WARN",
        "BLOCKED",
        "SUPPRESSED",
        "ACTIONABLE",
        "CONTEXT_ONLY",
        "ERROR"
      ]
    },
    "reason": {
      "type": ["string", "null"],
      "minLength": 1
    },
    "payload": {
      "type": "object",
      "additionalProperties": true
    }
  }
}
