{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://trading-agency.local/schemas/prompt-audit.schema.json",
  "title": "PromptAudit",
  "x-version": "0.1.0",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "prompt_id",
    "run_id",
    "cycle_id",
    "agent_name",
    "model",
    "prompt_class",
    "prompt_hash",
    "created_at",
    "redaction_status",
    "payload"
  ],
  "properties": {
    "schema_version": {
      "const": "0.1.0"
    },
    "prompt_id": {
      "type": "string",
      "minLength": 1
    },
    "run_id": {
      "type": ["string", "null"],
      "minLength": 1
    },
    "cycle_id": {
      "type": "string",
      "minLength": 1
    },
    "agent_name": {
      "type": "string",
      "minLength": 1
    },
    "model": {
      "type": "string",
      "minLength": 1
    },
    "prompt_class": {
      "type": "string",
      "minLength": 1
    },
    "prompt_hash": {
      "type": "string",
      "minLength": 16
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "redaction_status": {
      "type": "string",
      "enum": ["NO_SECRETS", "REDACTED", "BLOCKED_SECRET"]
    },
    "payload": {
      "type": "object",
      "additionalProperties": true
    }
  }
}
