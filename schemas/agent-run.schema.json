{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://trading-agency.local/schemas/agent-run.schema.json",
  "title": "AgentRun",
  "x-version": "0.1.0",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "run_id",
    "cycle_id",
    "agent_name",
    "status",
    "trigger",
    "started_at",
    "finished_at",
    "payload"
  ],
  "properties": {
    "schema_version": {
      "const": "0.1.0"
    },
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "cycle_id": {
      "type": "string",
      "minLength": 1
    },
    "agent_name": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": ["RUNNING", "SUCCEEDED", "FAILED", "CANCELLED"]
    },
    "trigger": {
      "type": "string",
      "enum": ["MANUAL", "SCHEDULED", "API", "SYSTEM", "TEST"]
    },
    "started_at": {
      "type": "string",
      "format": "date-time"
    },
    "finished_at": {
      "type": ["string", "null"],
      "format": "date-time"
    },
    "payload": {
      "type": "object",
      "additionalProperties": true
    }
  }
}
