{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://trading-agency.local/schemas/risk-snapshot.schema.json",
  "title": "RiskSnapshot",
  "x-version": "0.1.0",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "snapshot_id",
    "cycle_id",
    "ticker",
    "as_of",
    "generated_at",
    "gross_exposure_pct",
    "risk_level",
    "payload"
  ],
  "properties": {
    "schema_version": {
      "const": "0.1.0"
    },
    "snapshot_id": {
      "type": "string",
      "minLength": 1
    },
    "cycle_id": {
      "type": "string",
      "minLength": 1
    },
    "ticker": {
      "type": ["string", "null"],
      "pattern": "^[A-Z][A-Z0-9.-]{0,9}$"
    },
    "as_of": {
      "type": "string",
      "format": "date-time"
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "gross_exposure_pct": {
      "type": "number",
      "minimum": 0
    },
    "risk_level": {
      "type": "string",
      "enum": ["LOW", "MEDIUM", "HIGH", "BLOCKED", "UNKNOWN"]
    },
    "payload": {
      "type": "object",
      "additionalProperties": true
    }
  }
}
