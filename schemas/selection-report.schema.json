{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://trading-agency.local/schemas/selection-report.schema.json",
  "title": "SelectionReport",
  "x-version": "0.1.0",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "cycle_id",
    "ticker",
    "as_of",
    "generated_at",
    "final_action",
    "final_conviction",
    "deterministic",
    "llm_review",
    "policy_gates",
    "risk_flags",
    "evidence_pack",
    "trade_plan"
  ],
  "properties": {
    "schema_version": {
      "const": "0.1.0"
    },
    "cycle_id": {
      "type": "string",
      "minLength": 1
    },
    "ticker": {
      "type": "string",
      "pattern": "^[A-Z][A-Z0-9.-]{0,9}$"
    },
    "as_of": {
      "type": "string",
      "format": "date-time"
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "final_action": {
      "type": "string",
      "enum": ["BUY", "SELL", "SHORT", "COVER", "WATCH", "HOLD", "NO_TRADE", "CLOSE_REVIEW"]
    },
    "final_conviction": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "deterministic": {
      "$ref": "#/$defs/EngineDecision"
    },
    "llm_review": {
      "$ref": "#/$defs/LlmReview"
    },
    "policy_gates": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/GateResult"
      }
    },
    "risk_flags": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "evidence_pack": {
      "$ref": "https://trading-agency.local/schemas/evidence-pack.schema.json"
    },
    "trade_plan": {
      "type": ["object", "null"],
      "additionalProperties": false,
      "required": ["entry", "stop_loss", "take_profit", "position_size", "time_in_force"],
      "properties": {
        "entry": {
          "type": ["number", "null"]
        },
        "stop_loss": {
          "type": ["number", "null"]
        },
        "take_profit": {
          "type": ["number", "null"]
        },
        "position_size": {
          "type": ["number", "null"],
          "minimum": 0
        },
        "time_in_force": {
          "type": ["string", "null"],
          "minLength": 1
        },
        "notes": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  },
  "$defs": {
    "EngineDecision": {
      "type": "object",
      "additionalProperties": false,
      "required": ["action", "score", "conviction", "reason_codes", "blockers"],
      "properties": {
        "action": {
          "type": "string"
        },
        "score": {
          "type": "number"
        },
        "conviction": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "reason_codes": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "blockers": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "GateResult": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "status", "reason"],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "type": "string",
          "enum": ["PASS", "WARN", "BLOCK"]
        },
        "reason": {
          "type": "string"
        }
      }
    },
    "LlmReview": {
      "type": "object",
      "additionalProperties": false,
      "required": ["action", "confidence", "rationale", "supporting_factors", "concerns"],
      "properties": {
        "action": {
          "type": "string"
        },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "rationale": {
          "type": "string"
        },
        "supporting_factors": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "concerns": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}
