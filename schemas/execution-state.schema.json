{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://trading-agency.local/schemas/execution-state.schema.json",
  "title": "ExecutionState",
  "x-version": "0.1.0",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "state_id",
    "cycle_id",
    "ticker",
    "execution_id",
    "state",
    "event_time",
    "reason",
    "payload"
  ],
  "properties": {
    "schema_version": {
      "const": "0.1.0"
    },
    "state_id": {
      "type": "string",
      "minLength": 1
    },
    "cycle_id": {
      "type": "string",
      "minLength": 1
    },
    "ticker": {
      "type": ["string", "null"],
      "pattern": "^[A-Z][A-Z0-9.-]{0,9}$"
    },
    "execution_id": {
      "type": "string",
      "minLength": 1
    },
    "state": {
      "type": "string",
      "enum": ["PLANNED", "READY", "BLOCKED", "DISABLED", "SUBMITTED", "FILLED", "FAILED"]
    },
    "event_time": {
      "type": "string",
      "format": "date-time"
    },
    "reason": {
      "type": ["string", "null"],
      "minLength": 1
    },
    "payload": {
      "type": "object",
      "additionalProperties": true
    }
  }
}
