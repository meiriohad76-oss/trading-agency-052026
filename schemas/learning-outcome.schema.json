{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://trading-agency.local/schemas/learning-outcome.schema.json",
  "title": "LearningOutcome",
  "x-version": "0.1.0",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "generated_at",
    "status",
    "sample_count",
    "required_sample_count",
    "message",
    "requirements"
  ],
  "properties": {
    "schema_version": {
      "const": "0.1.0"
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "status": {
      "type": "string",
      "enum": ["PREMATURE", "READY"]
    },
    "sample_count": {
      "type": "integer",
      "minimum": 0
    },
    "required_sample_count": {
      "type": "integer",
      "minimum": 1
    },
    "message": {
      "type": "string",
      "minLength": 1
    },
    "requirements": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/Requirement"
      }
    },
    "metrics": {
      "type": "object",
      "additionalProperties": true
    },
    "recommendations": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/Recommendation"
      }
    },
    "near_miss_journal": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "$defs": {
    "Requirement": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "status", "reason"],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "type": "string",
          "enum": ["PASS", "WARN"]
        },
        "reason": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "Recommendation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "status", "reason"],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "type": "string",
          "enum": ["DISABLED", "READY", "WARN"]
        },
        "reason": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
