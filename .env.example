# Copy this file to .env for local development.
# Blank values are expected for external services.
# Database values below are local-only development defaults.

# Optional supervised LLM review. Disabled unless AGENCY_ENABLE_LLM_REVIEW=true.
# OpenAI platform API key, usually starting with sk-.
OPENAI_API_KEY=
OPENAI_LLM_REVIEW_MODEL=gpt-4.1-mini
OPENAI_ARTICLE_ANALYSIS_MODEL=gpt-5-nano
OPENAI_BASE_URL=https://api.openai.com/v1
AGENCY_ENABLE_LLM_REVIEW=false
AGENCY_LLM_REVIEW_MAX_CANDIDATES=10

# Optional Raspberry Pi / Open WebUI local LLM. Shadow-mode only; it writes
# advisory insight artifacts and cannot change risk, promotion, or order gates.
AGENCY_LOCAL_LLM_ENABLED=false
AGENCY_LOCAL_LLM_PROVIDER=openwebui
AGENCY_LOCAL_LLM_BASE_URL=http://raspberrypi.local:3000
AGENCY_LOCAL_LLM_API_KEY=
AGENCY_LOCAL_LLM_MODEL=
AGENCY_LOCAL_LLM_MODE=shadow
AGENCY_LOCAL_LLM_TIMEOUT_SECONDS=60

# Planned provider integrations. These are shown by provider readiness,
# but provider-specific connectors are enabled incrementally.
OPENFIGI_API_KEY=
BENZINGA_API_KEY=
UNUSUAL_WHALES_API_KEY=
FRED_API_KEY=
POLYGON_API_KEY=
MASSIVE_API_KEY=
MASSIVE_BASE_URL=https://api.polygon.io
# Local Massive REST request guardrails. Disabled by default for full coverage;
# set MASSIVE_API_LIMITS_ENABLED=true and a positive daily budget to re-enable.
MASSIVE_API_LIMITS_ENABLED=false
MASSIVE_API_DAILY_REQUEST_BUDGET=0
# 0 means no local per-minute pacing.
MASSIVE_API_MAX_REQUESTS_PER_MINUTE=0
MASSIVE_API_USAGE_DIR=research/results/massive-api-usage
THETADATA_USERNAME=
THETADATA_PASSWORD=

# Alpaca keys are required when research/config/live-refresh.local.json uses
# "market_data_provider": "alpaca". POLYGON_API_KEY or MASSIVE_API_KEY above
# is required when it uses "market_data_provider": "massive".
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
ALPACA_DATA_FEED=iex
ALPACA_DATA_ADJUSTMENT=all
ALPACA_DATA_BASE_URL=https://data.alpaca.markets
ALPACA_TRADING_BASE_URL=https://paper-api.alpaca.markets
ALPACA_TRADING_TIMEOUT_SECONDS=10
ALPACA_ALLOW_LIVE_TRADING=false

# Paper broker and portfolio policy gates. Keep broker submit disabled until
# you are ready to place Alpaca paper orders from approved agency previews.
AGENCY_ALPACA_BROKER_ENABLED=false
AGENCY_BROKER_SUBMIT_ENABLED=false
AGENCY_REQUIRE_HUMAN_APPROVAL_FOR_ORDERS=true
AGENCY_MIN_FINAL_CONVICTION=0.62
AGENCY_MAX_NEW_POSITIONS_PER_CYCLE=3
AGENCY_MAX_GROSS_EXPOSURE_PCT=100
AGENCY_DEFAULT_POSITION_PCT=10
AGENCY_TAKE_PROFIT_PCT=8
AGENCY_STOP_LOSS_PCT=4
AGENCY_TRAILING_STOP_PCT=3
AGENCY_HOURLY_LOSS_ALERT_PCT=1
AGENCY_PAPER_TRADE_PROMOTION_ENABLED=false
AGENCY_PAPER_TRADE_MIN_CONVICTION=0.90
AGENCY_PAPER_TRADE_MIN_SOURCE_COUNT=2
AGENCY_PAPER_TRADE_MIN_CONFIRMED_SIGNALS=2
AGENCY_PAPER_TRADE_MAX_PER_CYCLE=1
AGENCY_PAPER_TRADE_REQUIRE_POLICY_PASS=true
AGENCY_LEVERAGED_ALTERNATIVES_ENABLED=false
AGENCY_LEVERAGED_ALTERNATIVES_PATH=research/config/leveraged-alternatives.local.json
AGENCY_LEVERAGED_MIN_CONVICTION=0.85
AGENCY_MAX_LEVERAGED_POSITION_PCT=2
AGENCY_LEVERAGED_ETF_REVIEW_ENABLED=true
AGENCY_MIN_LEVERAGED_ETF_AVG_DOLLAR_VOLUME=0
AGENCY_ALLOW_DEFINED_RISK_OPTIONS=false
AGENCY_ALLOW_COVERED_OPTION_WRITES=false
AGENCY_MIN_OPTION_DAYS_TO_EXPIRATION=14
AGENCY_MAX_OPTION_DAYS_TO_EXPIRATION=60

# Required for SEC EDGAR calls. Use a contact string such as:
# Trading Agency your-email@example.com
SEC_USER_AGENT=

# Required when research/config/subscription-email.local.json uses
# "mode": "gmail", "outlook", or "imap". For Gmail/Outlook this is
# typically an app password or provider-specific mail password.
SUBSCRIPTION_EMAIL_USERNAME=
SUBSCRIPTION_EMAIL_PASSWORD=

DATA_REFRESH_STATUS_PATH=research/results/latest-data-refresh/data-refresh-status.json
LIVE_REFRESH_CONFIG_PATH=research/config/live-refresh.local.json

# Local development database. These match docker/postgres/init.sql.
DB_HOST=localhost
DB_PORT=5432
DB_NAME=agency
DB_USER=agency_app
DB_PASSWORD=agency
DB_CONNECT_TIMEOUT_SECONDS=1

# Keep the market-aware data refresh scheduler on for live operation.
AGENCY_SCHEDULER_ENABLED=true
