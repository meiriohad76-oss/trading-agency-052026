# Copy this file to .env for local development.
# Blank values are expected for external services.
# Database values below are local-only development defaults.

# Optional today; reserved for future LLM review calls.
OPENAI_API_KEY=

# Planned provider integrations. These are shown by provider readiness,
# but provider-specific connectors are enabled incrementally.
OPENFIGI_API_KEY=
BENZINGA_API_KEY=
UNUSUAL_WHALES_API_KEY=
FRED_API_KEY=
POLYGON_API_KEY=
MASSIVE_API_KEY=
THETADATA_USERNAME=
THETADATA_PASSWORD=

# Required when research/config/live-refresh.local.json uses
# "market_data_provider": "alpaca".
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
ALPACA_DATA_FEED=iex
ALPACA_DATA_ADJUSTMENT=all
ALPACA_DATA_BASE_URL=https://data.alpaca.markets

# Required for SEC EDGAR calls. Use a contact string such as:
# Trading Agency your-email@example.com
SEC_USER_AGENT=

DATA_REFRESH_STATUS_PATH=research/results/latest-data-refresh/data-refresh-status.json
LIVE_REFRESH_CONFIG_PATH=research/config/live-refresh.local.json

# Local development database. These match docker/postgres/init.sql.
DB_HOST=localhost
DB_PORT=5432
DB_NAME=agency
DB_USER=agency_app
DB_PASSWORD=agency
DB_CONNECT_TIMEOUT_SECONDS=1
